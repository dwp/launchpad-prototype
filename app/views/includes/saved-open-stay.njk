{% macro stayCard(stay, isOngoing) %}

{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}


{% set start = stay.startDate.day + "/" + stay.startDate.month + "/" + stay.startDate.year %}

{% if not isOngoing and stay.endDate %}
  {% set end = stay.endDate.day + "/" + stay.endDate.month + "/" + stay.endDate.year %}

{% endif %}

{{ govukSummaryList({
  card: {
    title: { text: stay.type or "Accommodation" },
    actions: {
      items: [
        {
          href: "/payability/v3/stay/" + stay.id + "/overview",
          text: "Edit",
          visuallyHiddenText: "of " + (stay.name or "accommodation")
        }
      ]
    }
  },
  rows: [
    {
      key: { text: "Accommodation name" },
      value: { text: stay.name or "Not provided" }
    },
    {
      key: { text: "Start date" },
      value: { text: start }
    }
  ]
  | addEndRow(isOngoing, end)  # see below
}) }}
{% endmacro %}


{# Helper filter: adds "end date" row only if it's a completed stay #}
{% macro addEndRow(isOngoing, end) %}
  {% if isOngoing %}
    {{ [] }}
  {% else %}
    {{
      [
        {
          key: { text: "End date" },
          value: { text: end }
        }
      ]
    }}
  {% endif %}
{% endmacro %}
